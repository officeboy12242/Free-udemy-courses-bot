# Course bot
BOT_TOKEN=
CHANNEL_ID=

# HTTP server port (Render sets PORT automatically)
PORT=10000

# Market dip alerts (Telegram). Default recipient: @Its_Mirror_Here
# For a private user they must /start your bot first; you can use numeric chat_id instead.
MARKET_ALERT_CHAT_ID=@Its_Mirror_Here

# Dip alert when intraday/last vs previous close drops by at least this %
DIP_THRESHOLD_PERCENT=1

# Seconds between market polls (yfinance; stay reasonable)
MARKET_POLL_INTERVAL=120

# Set to 0 to disable market polling (dashboard & API still work)
MARKET_FEATURES_ENABLED=1

# Optional: comma list yfinance_symbol:Label  e.g.  ^NSEI:Nifty 50,^BSESN:Sensex
# MARKET_SYMBOLS=^NSEI:Nifty 50,^BSESN:Sensex,NIFTYBEES.NS:Nifty BeES

# Optional: use same SQLite file as course dedupe
# DB_FILE=posted_courses.db

# Optional: enable GET /api/test-alert?secret=YOUR_SECRET (sample dip message → MARKET_ALERT_CHAT_ID)
# TEST_ALERT_SECRET=change-me

# Tech news auto-post (IST hours, comma-separated). Default: 10 AM and 10 PM
# NEWS_POST_HOURS=10,22

# Movie channel ID (where /movies "Post to Channel" sends results)
# MOVIES_CHANNEL_ID=-1001739791835

# ScraperAPI key to bypass Cloudflare on cloud deployments (free: 5k req/month)
# SCRAPER_API_KEY=

# Movie site base URLs — change these if a site goes down or moves domain
HDHUB_BASE_URL=https://new1.hdhub4u.limo
HDH_BASE_URL=https://4khdhub.link
MD_BASE_URL=https://new2.moviesdrives.my
M4U_BASE_URL=https://movies4u.ee
VEGA_BASE_URL=https://vegamovies.global
SDMP_BASE_URL=https://sd1.sdmoviespoint.trade
