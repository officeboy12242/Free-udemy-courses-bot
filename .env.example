# Course bot
BOT_TOKEN=
CHANNEL_ID=

# HTTP server port (Render sets PORT automatically)
PORT=10000

# Market dip alerts (Telegram). Default recipient: @Its_Mirror_Here
# For a private user they must /start your bot first; you can use numeric chat_id instead.
MARKET_ALERT_CHAT_ID=@Its_Mirror_Here

# Dip alert when intraday/last vs previous close drops by at least this %
DIP_THRESHOLD_PERCENT=1

# Seconds between market polls (yfinance; stay reasonable)
MARKET_POLL_INTERVAL=120

# Set to 0 to disable market polling (dashboard & API still work)
MARKET_FEATURES_ENABLED=1

# Optional: comma list yfinance_symbol:Label  e.g.  ^NSEI:Nifty 50,^BSESN:Sensex
# MARKET_SYMBOLS=^NSEI:Nifty 50,^BSESN:Sensex,NIFTYBEES.NS:Nifty BeES

# Optional: use same SQLite file as course dedupe
# DB_FILE=posted_courses.db

# Optional: enable GET /api/test-alert?secret=YOUR_SECRET (sample dip message → MARKET_ALERT_CHAT_ID)
# TEST_ALERT_SECRET=change-me

# Tech news auto-post (IST hours, comma-separated). Default: 10 AM and 10 PM
# NEWS_POST_HOURS=10,22

# Movie channel ID (where /movies "Post to Channel" sends results)
# MOVIES_CHANNEL_ID=-1001739791835

# ScraperAPI key to bypass Cloudflare on cloud deployments (free: 5k req/month)
# SCRAPER_API_KEY=

# Movie site base URLs — change these if a site goes down or moves domain
HDHUB_BASE_URL=https://new2.hdhub4u.cl
# HDHUB_SEARCH_API=https://search.pingora.fyi/collections/post/documents/search
HDHUB_SEARCH_ALERT_ENABLED=1
# HDHUB_SEARCH_ALERT_CHAT_ID=882130858
HDHUB_SEARCH_ALERT_COOLDOWN=1800

# Movies API speed (parallel search, short timeouts, 120s cache)
MOVIES_API_SOURCE_TIMEOUT=10
MOVIES_API_LINK_TIMEOUT=14
MOVIES_API_CACHE_TTL=120
MOVIES_API_MAX_WORKERS=6
HDH_BASE_URL=https://4khdhub.link
MD_BASE_URL=https://new2.moviesdrives.my
HDMOVIE2_BASE_URL=https://newhdmovie2.pro
VEGA_BASE_URL=https://vegamovies.global
SDMP_BASE_URL=https://sd1.sdmoviespoint.trade
BOLLYFLIX_BASE_URL=https://new.bollyflix.gd
MOVIESMOD_BASE_URL=https://moviesmod.farm
ATOZ_BASE_URL=https://atoz.cinemaz.workers.dev
ZEEFLIZ_BASE_URL=https://zeefliz.beer

# Admin user ID (numeric chat ID) — required for /updateapi command
# Get your ID by running /myid in the bot
# ADMIN_ID=882130858

# Owner ID (numeric chat ID) — full access to all features
# Regular users only see Udemy enroller (20 courses/day limit)
# Owner sees: movies, news, market, premium management
# Get your ID by running /myid in the bot
OWNER_ID=

# MongoDB Atlas connection string (required for persistent data)
# Data persists across deployments with MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=myApp

# For large file uploads (up to ~2GB) in the owner course archive feature (/search_courses + download)
# Get these from https://my.telegram.org (create an app, use the api_id and api_hash)
# Required for uploading zips larger than ~50MB to Telegram channels using the full MTProto API.
API_ID=
API_HASH=

# Multiple bot tokens for parallel downloads and uploads (comma-separated)
# Each bot should be admin in CHANNEL_ID. More bots = faster downloads & uploads!
# Example: UPLOAD_BOT_TOKENS=token1,token2,token3,token4
# Leave empty to use only main BOT_TOKEN (slower but simpler)
UPLOAD_BOT_TOKENS=

# Archive/download working storage.
# IMPORTANT on Render: /tmp is usually limited to ~2GB and can evict/crash the instance.
# Add a Render Persistent Disk and set this to the mounted path:
# ARCHIVE_WORK_DIR=/var/data/udemy_archives
ARCHIVE_WORK_DIR=/var/data/udemy_archives

# Used if ARCHIVE_WORK_DIR is not writable/mounted yet.
# For local/dev this can be a relative folder.
ARCHIVE_FALLBACK_WORK_DIR=archive_work

# Minimum free disk required before starting/creating ZIPs.
ARCHIVE_MIN_FREE_GB=1.5

# For small local tests only. Keep 0 in production so /tmp 2GB does not crash the app.
ALLOW_TMP_ARCHIVES=0

# Optional: BSE Sensex option chain cache TTL (seconds). Uses free BSE India API — no key needed.
# BSE_CHAIN_CACHE_TTL=120

# F&O auto-alert quality filters (1=on, fewer but higher-conviction alerts)
# FNO_STRICT_FILTERS=1
# FNO_MIN_LEG_VOLUME=25
# FNO_MAX_SPREAD_PCT=12
# FNO_MIN_ADX=14
# ORB_MIN_BREAK_PCT=0.02
# FNO_REQUIRE_EMA_ALIGN=0
# FNO_CONFLUENCE_MIN_LAYERS=3
# FNO_SKIP_LUNCH=0
# FNO_MAX_ALERTS_PER_INDEX=2
# FNO_MACD_MTF_ENABLED=1
# FNO_MACD_REQUIRE_5M=0
# F&O summary storage: uses MONGODB_URI when set (survives Render redeploy)
# FNO_USE_MONGODB=auto
# FNO_ALERT_RETENTION_DAYS=30

# Paper trade portfolio capital (₹) — used for P&L in summaries
# FNO_PAPER_CAPITAL=50000
